{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Firebase Emulators",
			"type": "shell",
			"command": "source ~/.zshrc &&firebase emulators:start --import ./firebase-snapshot --inspect-functions",
			"args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
			"isBackground": true,
            "problemMatcher": {
                "owner": "firebase",
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ]
            }
		},
		{
			"label": "Start npm",
			"type": "shell",
			"command": "npm start",
			"args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
			"isBackground": true,
            "problemMatcher": {
                "owner": "npm",
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ]
            }
		},
		{
			"label": "Save Snapshot",
			"type": "shell",
			"command": "firebase emulators:export ./firebase-snapshot",
			"args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
			"isBackground": true,
            "problemMatcher": {
                "owner": "firebase",
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ]
            }
		},
		{
			"label": "Build 4 Deploy",
			"type": "shell",
			"command": "npm run-script build4deploy",
			"args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
			"isBackground": true
		},
        {
            "label": "Deploy to Firebase",
            "type": "shell",
            "command": "firebase deploy",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true
        }
	]
}